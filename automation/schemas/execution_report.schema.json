{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ExecutionReport",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "attempt_id",
    "verdict",
    "confidence",
    "problems",
    "patches",
    "relaunch",
    "human_escalation"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "attempt_id": {
      "type": "string"
    },
    "verdict": {
      "type": "string",
      "enum": [
        "config_issue",
        "model_limit",
        "framework_bug",
        "inconclusive"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "problems": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "severity",
          "component",
          "symptom",
          "root_cause",
          "evidence",
          "proposed_fix_summary"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": ["P0", "P1", "P2"]
          },
          "component": {
            "type": "string"
          },
          "symptom": {
            "type": "string"
          },
          "root_cause": {
            "type": "string"
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "proposed_fix_summary": {
            "type": "string"
          }
        }
      }
    },
    "patches": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "target_file",
          "action",
          "anchor",
          "old_sha256",
          "new_text"
        ],
        "properties": {
          "target_file": {
            "type": "string"
          },
          "action": {
            "type": "string"
          },
          "anchor": {
            "type": "string"
          },
          "old_sha256": {
            "type": "string"
          },
          "new_text": {
            "type": "string"
          }
        }
      }
    },
    "relaunch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "recommended",
        "change_team_name",
        "reasoning_effort",
        "notes"
      ],
      "properties": {
        "recommended": {
          "type": "boolean"
        },
        "change_team_name": {
          "type": "boolean"
        },
        "reasoning_effort": {
          "type": "string"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "human_escalation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "reason"
      ],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "reason": {
          "type": "string"
        }
      }
    }
  }
}

